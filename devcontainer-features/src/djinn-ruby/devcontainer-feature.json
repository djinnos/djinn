{
  "id": "djinn-ruby",
  "version": "1.0.0",
  "name": "Djinn Ruby",
  "description": "Ruby (via rbenv) + ruby-lsp + scip-ruby.",
  "documentationURL": "https://github.com/djinnos/djinn/tree/main/devcontainer-features/src/djinn-ruby",
  "options": {
    "version": {
      "type": "string",
      "default": "3.4",
      "description": "Ruby version passed to `rbenv install`. 3.4 is the current production default (2026). Accepts anything rbenv/ruby-build understands: `3.4`, `3.4.4`, `3.3.7`, etc."
    }
  },
  "installsAfter": [
    "ghcr.io/djinnos/djinn-agent-worker"
  ],
  "containerEnv": {
    "RBENV_ROOT": "/usr/local/rbenv",
    "PATH": "/usr/local/rbenv/shims:/usr/local/rbenv/bin:${PATH}"
  }
}
