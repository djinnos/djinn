{
  "setup": [
    {
      "name": "server-shared-target",
      "command": "mkdir -p server/.cargo && sed -i \"s|^target-dir.*|target-dir = \\\"/tmp/djinn-targets/$(basename $PWD)-server\\\"|\" server/.cargo/config.toml",
      "timeout_secs": 5
    }
  ],
  "verification_rules": [
    {
      "match": "server/crates/djinn-agent/**",
      "commands": [
        "cd server && cargo test -p djinn-agent",
        "cd server && cargo clippy -p djinn-agent --all-targets -- -D warnings"
      ]
    },
    {
      "match": "server/crates/djinn-core/**",
      "commands": [
        "cd server && cargo test -p djinn-core",
        "cd server && cargo clippy -p djinn-core --all-targets -- -D warnings"
      ]
    },
    {
      "match": "server/crates/djinn-db/**",
      "commands": [
        "cd server && cargo test -p djinn-db",
        "cd server && cargo clippy -p djinn-db --all-targets -- -D warnings"
      ]
    },
    {
      "match": "server/crates/djinn-git/**",
      "commands": [
        "cd server && cargo test -p djinn-git",
        "cd server && cargo clippy -p djinn-git --all-targets -- -D warnings"
      ]
    },
    {
      "match": "server/crates/djinn-mcp/**",
      "commands": [
        "cd server && cargo test -p djinn-mcp",
        "cd server && cargo clippy -p djinn-mcp --all-targets -- -D warnings"
      ]
    },
    {
      "match": "server/crates/djinn-provider/**",
      "commands": [
        "cd server && cargo test -p djinn-provider",
        "cd server && cargo clippy -p djinn-provider --all-targets -- -D warnings"
      ]
    },
    {
      "match": "server/src/**",
      "commands": [
        "cd server && cargo test -p djinn-server",
        "cd server && cargo clippy -p djinn-server --all-targets -- -D warnings"
      ]
    },
    {
      "match": "desktop/{src,electron}/**",
      "commands": [
        "cd desktop && pnpm install --frozen-lockfile",
        "cd desktop && pnpm tsc --noEmit",
        "cd desktop && pnpm test"
      ]
    }
  ]
}
