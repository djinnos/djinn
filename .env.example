# Copy to .env and edit for your machine.
#
# Host path mounted into the server container as /workspace. The server needs
# RW access to your project checkouts to read code, write changes, and run git.
DJINN_WORKSPACE_ROOT=${HOME}

# Log verbosity for the djinn-server container.
RUST_LOG=info

# --- DATABASE_URL (used by sqlx macros during cargo build) --------------------
# Only needed locally when regenerating the offline cache with
# `make sqlx-prepare`. Docker builds consume the committed server/.sqlx/
# cache via SQLX_OFFLINE=true and never touch this.
DATABASE_URL=mysql://root@127.0.0.1:3306/djinn

# --- Langfuse (optional, requires --profile observability) -------------------
# Sign up at http://localhost:5000 after the observability profile boots, then
# paste your keys here and uncomment.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://langfuse-web:3000

# --- OAuth providers (optional) ----------------------------------------------
# Tokens normally live under ~/.djinn (bind-mounted) so these env vars are only
# needed for non-interactive first-time setup.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
