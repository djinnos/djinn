          "nullable": true,
          "type": "boolean"
        },
        "create_epic": {
          "description": "When `true` (default), a matching `Epic` shell is created for\n`work_shape ∈ {task, epic, spike}` ADRs.  Architectural ADRs\nnever spawn an epic regardless of this flag.",
          "nullable": true,
          "type": "boolean"
        },
        "id": {
          "description": "File stem of the proposed ADR, e.g. `\"adr-052-foo\"`.",
          "type": "string"
        },
        "project": {
          "description": "Absolute project path.",
          "type": "string"
        },
        "title": {
          "description": "Optional accepted title override. Defaults to the draft title.",
