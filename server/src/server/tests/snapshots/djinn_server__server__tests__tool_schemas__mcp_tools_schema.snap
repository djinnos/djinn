          "nullable": true,
          "type": "array"
        },
        "model_preference": {
          "description": "Preferred model ID (falls back to project default).",
          "nullable": true,
          "type": "string"
        },
        "name": {
          "description": "Unique agent name within the project.",
          "type": "string"
        },
        "project": {
          "description": "Absolute project path.",
          "type": "string"
        },
        "skills": {
          "description": "Skills (prompt templates) available to this agent.",
