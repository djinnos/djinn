            "$ref": "#/$defs/AnyJson"
          },
          "nullable": true,
          "type": "array"
        },
        "system_prompt_extensions": {
          "description": "Additional system prompt content appended to the base role prompt.",
          "nullable": true,
          "type": "string"
        },
        "verification_command": {
          "description": "Custom verification command (falls back to project default).",
          "nullable": true,
          "type": "string"
        }
      },
      "required": [
        "project",
        "name",
        "base_role"
      ],
