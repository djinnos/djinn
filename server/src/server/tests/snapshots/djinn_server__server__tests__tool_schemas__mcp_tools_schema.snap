  {
    "input_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "direction": {
          "default": null,
          "description": "Edge direction filter for `neighbors`: `incoming`, `outgoing`, or omit for both.",
          "nullable": true,
          "type": "string"
        },
        "edge_kind": {
          "default": null,
          "description": "Optional edge-kind filter for `edges`.",
          "nullable": true,
          "type": "string"
        },
        "from": {
          "default": null,
          "description": "Source node for `path`.",
          "nullable": true,
          "type": "string"
        },
        "from_glob": {
          "default": null,
          "description": "Source path glob for `edges`.",
          "nullable": true,
          "type": "string"
        },
        "group_by": {
          "default": null,
          "description": "Group results: only `file` is supported. Applies to `impact`/`neighbors`.",
          "nullable": true,
          "type": "string"
        },
        "key": {
          "default": null,
          "description": "The node key to query (file path or SCIP symbol string).\nRequired for `neighbors`, `impact`, `implementations`, and `describe`.",
          "nullable": true,
          "type": "string"
        },
        "kind_filter": {
          "default": null,
          "description": "Node kind filter for `ranked`/`search`/`cycles`/`orphans`: `file` or `symbol`.",
          "nullable": true,
          "type": "string"
        },
        "limit": {
          "default": null,
          "description": "Maximum results for `ranked`/`search`/`orphans`/`edges`/`neighbors`\n(default 20) or max traversal depth for `impact` (default 3).",
          "format": "int64",
          "nullable": true,
          "type": "integer"
        },
        "max_depth": {
          "default": null,
          "description": "Optional max depth for `path`.",
          "format": "int64",
          "nullable": true,
          "type": "integer"
        },
        "min_size": {
          "default": null,
          "description": "Minimum SCC size for `cycles` (default 2).",
          "format": "int64",
          "nullable": true,
          "type": "integer"
        },
        "operation": {
          "description": "The operation to perform.\nOne of: `neighbors`, `ranked`, `impact`, `implementations`,\n`search`, `cycles`, `orphans`, `path`, `edges`, `diff`, `describe`,\n`status`.",
          "type": "string"
        },
        "project_path": {
          "description": "Path to the project root (used to locate the graph).",
          "type": "string"
        },
        "query": {
          "default": null,
          "description": "Substring query for `search`.",
          "nullable": true,
          "type": "string"
        },
        "since": {
          "default": null,
          "description": "Diff base selector for `diff`. Currently only `previous` is supported.",
          "nullable": true,
          "type": "string"
        },
        "sort_by": {
          "default": null,
          "description": "Sort key for `ranked`: `pagerank` (default), `in_degree`, `out_degree`,\nor `total_degree`.",
          "nullable": true,
          "type": "string"
        },
        "to": {
          "default": null,
          "description": "Destination node for `path`.",
          "nullable": true,
          "type": "string"
        },
        "to_glob": {
          "default": null,
          "description": "Destination path glob for `edges`.",
          "nullable": true,
          "type": "string"
        },
        "visibility": {
          "default": null,
          "description": "Visibility filter for `orphans`: `public`, `private`, or `any` (default).",
          "nullable": true,
          "type": "string"
        }
      },
      "required": [
        "operation",
        "project_path"
      ],
      "title": "CodeGraphParams",
      "type": "object"
    },
