      "type": "object"
    },
    "name": "memory_graph",
    "output_schema": {
      "$defs": {
        "GraphEdge": {
          "description": "A resolved wikilink edge between two notes.",
          "properties": {
            "raw_text": {
              "type": "string"
            },
            "source_id": {
              "type": "string"
            },
            "target_id": {
              "type": "string"
            }
          },
          "required": [
            "source_id",
            "target_id",
            "raw_text"
          ],
          "type": "object"
        },
        "GraphNode": {
          "description": "A knowledge graph node (note with connection metadata).",
          "properties": {
            "connection_count": {
              "description": "Total resolved edges incident to this node (inbound + outbound).",
              "format": "int64",
              "type": "integer"
            },
            "folder": {
              "type": "string"
            },
            "id": {
              "type": "string"
            },
            "note_type": {
              "type": "string"
            },
            "permalink": {
              "type": "string"
            },
            "title": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "permalink",
            "title",
            "note_type",
            "folder",
            "connection_count"
          ],
          "type": "object"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "edges": {
          "items": {
            "$ref": "#/$defs/GraphEdge"
          },
          "type": "array"
        },
        "error": {
          "nullable": true,
          "type": "string"
        },
        "nodes": {
          "items": {
            "$ref": "#/$defs/GraphNode"
          },
          "type": "array"
        }
      },
      "required": [
        "nodes",
        "edges"
      ],
      "title": "MemoryGraphResponse",
      "type": "object"
    }
  },
