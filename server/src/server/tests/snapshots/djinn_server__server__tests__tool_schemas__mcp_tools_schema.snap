  {
    "input_schema": {
      "$defs": {
        "AcceptanceCriterionItem": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/$defs/AcceptanceCriterionStatus"
            }
          ]
        },
        "AcceptanceCriterionStatus": {
          "properties": {
            "criterion": {
              "type": "string"
            },
            "met": {
              "default": false,
              "type": "boolean"
            }
          },
          "required": [
            "criterion"
          ],
          "type": "object"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "acceptance_criteria": {
          "description": "Full replacement for acceptance_criteria.",
          "items": {
            "$ref": "#/$defs/AcceptanceCriterionItem"
          },
          "nullable": true,
          "type": "array"
        },
        "agent_type": {
          "description": "Specialist role name to assign (set None/\"\" to clear).",
          "nullable": true,
          "type": "string"
        },
        "blocked_by_add": {
          "description": "Task IDs (UUID or short_id) to add as blockers of this task.",
          "items": {
            "type": "string"
          },
          "nullable": true,
          "type": "array"
        },
        "blocked_by_remove": {
          "description": "Task IDs (UUID or short_id) to remove as blockers of this task.",
          "items": {
            "type": "string"
          },
          "nullable": true,
          "type": "array"
        },
        "description": {
          "nullable": true,
          "type": "string"
        },
        "design": {
          "nullable": true,
          "type": "string"
        },
        "epic_id": {
          "description": "New parent epic UUID or short_id.",
          "nullable": true,
          "type": "string"
        },
        "id": {
          "description": "Task UUID or short_id.",
          "type": "string"
        },
        "labels_add": {
          "description": "Labels to add.",
          "items": {
            "type": "string"
          },
          "nullable": true,
          "type": "array"
        },
        "labels_remove": {
          "description": "Labels to remove.",
          "items": {
            "type": "string"
          },
          "nullable": true,
          "type": "array"
        },
        "memory_refs_add": {
          "description": "Memory note permalinks to add to this task.",
          "items": {
            "type": "string"
          },
          "nullable": true,
          "type": "array"
        },
        "memory_refs_remove": {
