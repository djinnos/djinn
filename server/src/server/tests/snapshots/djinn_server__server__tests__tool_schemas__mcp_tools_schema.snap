  {
    "input_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "key": {
          "description": "Optional settings key to fetch (defaults to settings.raw).",
          "nullable": true,
          "type": "string"
        }
      },
      "title": "SettingsGetParams",
      "type": "object"
    },
    "name": "settings_get",
    "output_schema": {
      "$defs": {
        "DjinnSettings": {
          "additionalProperties": false,
          "description": "Typed settings schema. Unknown fields are rejected at parse time.",
          "properties": {
            "dispatch_limit": {
              "description": "Maximum number of tasks to dispatch per cycle (default 50).",
              "format": "int64",
              "nullable": true,
              "type": "integer"
            },
            "langfuse_endpoint": {
              "description": "Langfuse OTLP endpoint URL (defaults to `http://localhost:3000/api/public/otel`).",
              "nullable": true,
              "type": "string"
            },
            "langfuse_public_key": {
              "description": "Langfuse public key for OTLP trace export (e.g. `pk-lf-...`).",
              "nullable": true,
              "type": "string"
            },
            "langfuse_secret_key": {
              "description": "Langfuse secret key for OTLP trace export (e.g. `sk-lf-...`).",
              "nullable": true,
              "type": "string"
            },
            "max_sessions": {
              "additionalProperties": {
                "format": "int64",
                "type": "integer"
              },
              "description": "Per-model concurrent session caps, e.g. `{\"openai/gpt-4o\": 4}`.",
              "nullable": true,
              "type": "object"
            },
            "memory_mount_enabled": {
              "description": "Enable the ADR-057 Linux memory mount. Disabled by default.",
              "nullable": true,
              "type": "boolean"
            },
            "memory_mount_path": {
              "description": "Absolute filesystem path where the Linux FUSE mount should be attached.",
              "nullable": true,
              "type": "string"
            },
            "models": {
              "description": "Ordered list of models available to agents, e.g. `[\"openai/gpt-4o\"]`.",
              "items": {
                "type": "string"
              },
              "nullable": true,
              "type": "array"
            }
          },
          "type": "object"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "error": {
          "nullable": true,
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "key": {
          "type": "string"
        },
        "raw_value": {
          "nullable": true,
          "type": "string"
        },
        "settings": {
          "$ref": "#/$defs/DjinnSettings"
        }
      },
      "required": [
        "key",
        "exists",
        "settings"
      ],
      "title": "SettingsGetResponse",
      "type": "object"
    }
  },
