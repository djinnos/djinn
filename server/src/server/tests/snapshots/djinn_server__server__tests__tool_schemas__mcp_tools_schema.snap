            "title": {
              "description": "Title pulled from frontmatter or the first H1.",
              "type": "string"
            },
            "work_shape": {
              "description": "Work shape hint (`\"task\"` | `\"epic\"` | `\"architectural\"` | `\"spike\"`).",
              "nullable": true,
              "type": "string"
            }
          },
          "required": [
            "id",
            "path",
            "title"
