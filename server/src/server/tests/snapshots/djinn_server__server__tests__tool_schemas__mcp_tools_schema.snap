  {
    "input_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "dispatch_limit": {
          "description": "Maximum number of tasks to dispatch per cycle. Omit to keep current value.",
          "format": "int64",
          "nullable": true,
          "type": "integer"
        },
        "langfuse_endpoint": {
          "description": "Langfuse OTLP endpoint URL (defaults to \"http://localhost:3000/api/public/otel\"). Set to \"\" to disable. Omit to keep current value.",
          "nullable": true,
          "type": "string"
        },
        "langfuse_public_key": {
          "description": "Langfuse public key for LLM observability (e.g. \"pk-lf-...\"). Set to \"\" to disable. Omit to keep current value.",
          "nullable": true,
          "type": "string"
        },
        "langfuse_secret_key": {
          "description": "Langfuse secret key for LLM observability (e.g. \"sk-lf-...\"). Set to \"\" to disable. Omit to keep current value.",
          "nullable": true,
          "type": "string"
        },
        "max_sessions": {
          "additionalProperties": {
            "format": "int64",
            "type": "integer"
          },
          "description": "Per-model concurrent session caps (e.g. {\"openai/gpt-4o\": 4}). Omit to keep current value.",
          "nullable": true,
          "type": "object"
        },
        "memory_mount_enabled": {
          "description": "Enable the Linux-only ADR-057 memory FUSE mount. Disabled by default; requires a Linux build with the `memory-mount` cargo feature.",
          "nullable": true,
          "type": "boolean"
        },
        "memory_mount_path": {
          "description": "Absolute path for the Linux memory mount. The directory must already exist and be empty at startup.",
          "nullable": true,
          "type": "string"
        },
        "models": {
          "description": "Ordered list of models available to all agents (e.g. [\"openai/gpt-4o\"]). Omit to keep current value.",
          "items": {
            "type": "string"
          },
          "nullable": true,
          "type": "array"
        }
      },
      "title": "SettingsSetParams",
      "type": "object"
    },
    "name": "settings_set",
    "output_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "applied": {
          "type": "boolean"
        },
        "error": {
          "nullable": true,
          "type": "string"
        },
        "ok": {
          "type": "boolean"
        }
      },
      "required": [
        "ok",
        "applied"
      ],
      "title": "SettingsSetResponse",
      "type": "object"
    }
  },
