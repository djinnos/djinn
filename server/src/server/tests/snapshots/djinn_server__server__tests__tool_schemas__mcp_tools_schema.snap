          "description": "Task UUID or short_id.",
          "type": "string"
        },
        "project": {
          "description": "Absolute project path.",
          "type": "string"
        },
        "reason": {
          "description": "Required for: verification_fail, release_verification,\ntask_review_reject, task_review_reject_conflict,\npr_changes_requested,\nreopen, release, release_task_review, force_close.",
          "nullable": true,
          "type": "string"
        },
        "target_status": {
          "description": "Required when action = \"user_override\". Allowed values: open, in_progress,\nverifying, needs_task_review, in_task_review, approved, pr_draft, pr_review, closed.",
          "nullable": true,
          "type": "string"
        }
      },
