          "description": "Transition action: start, submit_verification,\nverification_pass, verification_fail, release_verification,\nsubmit_task_review, task_review_start,\ntask_review_reject, task_review_reject_conflict, task_review_approve,\npr_created, pr_undraft, pr_ci_failed, pr_conflict,\npr_merge, pr_changes_requested,\nreopen, close, release, release_task_review, force_close,\nuser_override.",
          "type": "string"
        },
        "actor_id": {
          "nullable": true,
          "type": "string"
        },
        "actor_role": {
          "nullable": true,
          "type": "string"
        },
