              "type": "string"
            },
            "id": {
              "type": "string"
            },
            "last_accessed": {
              "type": "string"
            },
            "note_type": {
              "type": "string"
            },
            "permalink": {
              "type": "string"
            },
            "project_id": {
              "type": "string"
            },
            "tags": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "title": {
              "type": "string"
            },
            "updated_at": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "project_id",
            "permalink",
            "title",
            "file_path",
            "note_type",
            "folder",
            "tags",
            "content",
            "created_at",
            "updated_at",
            "last_accessed"
          ],
          "type": "object"
        },
        "NoteAbstract": {
          "description": "L0 note abstract payload used in tiered context responses.",
          "properties": {
            "abstract_text": {
              "type": "string"
            },
            "id": {
              "type": "string"
            },
            "note_type": {
              "type": "string"
            },
            "permalink": {
              "type": "string"
            },
            "score": {
              "format": "float",
              "nullable": true,
              "type": "number"
            },
            "superseded": {
              "description": "True when this note has been superseded by a newer note (stale-citation\nconfidence signal applied). Consumers should treat the content as\npotentially outdated.",
              "type": "boolean"
            },
            "title": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "permalink",
            "title",
            "note_type",
            "abstract_text"
          ],
          "type": "object"
        },
        "NoteOverview": {
          "description": "L1 note overview payload used in tiered context responses.",
          "properties": {
            "id": {
              "type": "string"
            },
            "note_type": {
              "type": "string"
            },
            "overview_text": {
              "type": "string"
            },
            "permalink": {
              "type": "string"
            },
            "score": {
              "format": "float",
              "nullable": true,
              "type": "number"
            },
            "superseded": {
              "description": "True when this note has been superseded by a newer note (stale-citation\nconfidence signal applied). Consumers should treat the content as\npotentially outdated.",
              "type": "boolean"
            },
            "title": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "permalink",
            "title",
            "note_type",
            "overview_text"
          ],
          "type": "object"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "error": {
          "nullable": true,
          "type": "string"
        },
        "primary": {
          "items": {
            "$ref": "#/$defs/MemoryNoteView"
          },
          "type": "array"
        },
        "related_l0": {
          "items": {
            "$ref": "#/$defs/NoteAbstract"
          },
          "type": "array"
        },
        "related_l1": {
          "items": {
            "$ref": "#/$defs/NoteOverview"
          },
          "type": "array"
        }
      },
      "required": [
