        },
        "operation": {
          "description": "Operation: \"append\", \"prepend\", \"find_replace\", \"replace_section\".",
          "type": "string"
        },
        "project": {
          "type": "string"
        },
        "section": {
          "description": "Required for replace_section: heading text identifying the section.",
          "nullable": true,
          "type": "string"
        },
        "type": {
          "description": "If provided and different from current type, move the note to the new\ntype's folder. Allowed values same as memory_write type.",
          "nullable": true,
          "type": "string"
        }
      },
      "required": [
        "project",
        "identifier",
        "operation",
        "content"
      ],
      "title": "EditParams",
      "type": "object"
    },
