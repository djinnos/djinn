              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "originating_adr_id": {
              "description": "ADR-051 Epic C — mirrors `Epic::originating_adr_id`.",
              "nullable": true,
              "type": "string"
            },
            "owner": {
              "type": "string"
            },
            "short_id": {
              "type": "string"
            },
            "status": {
              "type": "string"
            },
            "title": {
              "type": "string"
            },
            "updated_at": {
              "type": "string"
            }
          },
          "required": [
