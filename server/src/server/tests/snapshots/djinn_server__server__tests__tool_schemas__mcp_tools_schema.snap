            "type": "string"
          },
          "nullable": true,
          "type": "array"
        },
        "originating_adr_id": {
          "description": "ADR-051 Epic C — slug of the accepted ADR that spawned this\nepic.  Threaded into the breakdown Planner's session context\nso downstream task creation inherits the architectural rationale.",
          "nullable": true,
          "type": "string"
        },
        "owner": {
          "nullable": true,
          "type": "string"
        },
        "project": {
          "description": "Absolute project path.",
          "type": "string"
        },
        "status": {
          "description": "Initial status: \"proposed\", \"drafting\" (default), or \"open\".\nProposed epics (ADR-051 Epic C) are architect-drafted shells\nthat never trigger auto-dispatch until explicitly accepted.",
          "nullable": true,
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "project",
        "title"
