# ── GitHub App (repo access + web sign-in) ───────────────────────────────────
# Create a GitHub App (see docs/GITHUB_APP_SETUP.md). This replaces the
# classic OAuth App that used to power sign-in and repo operations. All
# repo list/clone/fetch calls now run under installation access tokens, and
# commits made server-side are attributed to the App's bot identity
# (`djinn-bot[bot]`).

# Numeric App ID, shown on the App's "About" settings page.
GITHUB_APP_ID=

# Slug portion of the App's public URL (`https://github.com/apps/<slug>`).
# Used to build the install URL returned by the `github_app_install_url`
# MCP tool and by `/auth/github/start?install=1`.
GITHUB_APP_SLUG=

# RSA private key PEM for signing App JWTs. Paste the full multi-line PEM
# between double quotes (`.env` loaders preserve newlines) OR use
# GITHUB_APP_PRIVATE_KEY_PATH to point at a file on disk. The server reads
# whichever is populated; the inline form wins.
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GITHUB_APP_PRIVATE_KEY_PATH=

# User-to-server OAuth credentials for the GitHub App (distinct from the
# App ID above). These drive the `/auth/github/*` browser sign-in flow.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# ── Legacy aliases (deprecated; will be removed next release) ────────────────
# The server falls back to these names if the GITHUB_APP_* equivalents are
# empty, and logs a deprecation warning on every use. Migrate your .env.
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# Public base URL of the djinn server; used to build the OAuth callback URL
# that GitHub redirects back to. In production this should be the HTTPS URL
# your reverse proxy exposes.
DJINN_PUBLIC_URL=http://127.0.0.1:8372

# Force `Secure` on session cookies regardless of DJINN_PUBLIC_URL scheme.
# Leave unset for localhost dev (cookies drop the Secure attribute so Chrome
# will retain them over plain HTTP). Set to `true` behind a TLS proxy that
# terminates HTTPS and forwards plain HTTP upstream.
# DJINN_COOKIE_SECURE=true
