# ── GitHub user OAuth (web client sign-in) ──────────────────────────────────
# Register an OAuth App at https://github.com/settings/developers and paste
# the credentials below. The callback URL configured on GitHub must match
# `${DJINN_PUBLIC_URL}/auth/github/callback`.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Public base URL of the djinn server; used to build the OAuth callback URL
# that GitHub redirects back to. In production this should be the HTTPS URL
# your reverse proxy exposes.
DJINN_PUBLIC_URL=http://127.0.0.1:8372

# Force `Secure` on session cookies regardless of DJINN_PUBLIC_URL scheme.
# Leave unset for localhost dev (cookies drop the Secure attribute so Chrome
# will retain them over plain HTTP). Set to `true` behind a TLS proxy that
# terminates HTTPS and forwards plain HTTP upstream.
# DJINN_COOKIE_SECURE=true
