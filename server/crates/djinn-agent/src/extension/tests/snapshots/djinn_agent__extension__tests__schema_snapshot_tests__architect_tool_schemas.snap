  {
    "concurrent_safe": false,
    "description": "Compatibility fallback for note creation when filesystem writes are unavailable. Prefer filesystem note CRUD via the mounted memory tree or checked-in `.djinn/` files. When mounted, `.djinn/memory/` reflects the current session-selected task/worktree view and falls back to canonical `main` when no task view is available; no explicit branch directories are exposed in this slice. Type is required and determines storage folder (adr->decisions/, pattern->patterns/, case->cases/, pitfall->pitfalls/, research->research/, requirement->requirements/, reference->reference/, design->design/, tech_spike->research/technical, session->research/sessions). Singleton types (brief, roadmap) write a fixed file — one per project. Use [[wikilinks]] in content to connect notes.",
    "inputSchema": {
      "properties": {
        "content": {
          "description": "Markdown content of the note. Use [[wikilinks]] to connect to other notes.",
          "type": "string"
        },
        "status": {
          "description": "Optional explicit status. For ADRs, use \"proposed\" to route into .djinn/decisions/proposed/.",
          "type": "string"
        },
        "tags": {
          "description": "Optional tags for categorisation",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "title": {
          "description": "Note title",
          "type": "string"
        },
        "type": {
          "description": "Note type: adr, pattern, case, pitfall, research, requirement, reference, design, tech_spike, session, brief (singleton), roadmap (singleton)",
          "type": "string"
        }
      },
      "required": [
        "title",
        "content",
        "type"
      ],
      "type": "object"
    },
    "name": "memory_write"
  },
  {
    "concurrent_safe": false,
    "description": "Compatibility fallback for note edits when filesystem writes are unavailable. Prefer filesystem note CRUD via the mounted memory tree or checked-in `.djinn/` files. When mounted, `.djinn/memory/` reflects the current session-selected task/worktree view and falls back to canonical `main` when no task view is available; no explicit branch directories are exposed in this slice. Operations: \"append\" (add to end), \"prepend\" (add after frontmatter), \"find_replace\" (exact text replacement, requires find_text), \"replace_section\" (replace content under a markdown heading, requires section).",
    "inputSchema": {
      "properties": {
        "content": {
          "description": "New content to insert or replace with",
          "type": "string"
        },
        "find_text": {
          "description": "Required for find_replace: exact text to search for",
          "type": "string"
        },
        "identifier": {
          "description": "Note permalink or title",
          "type": "string"
        },
        "operation": {
          "description": "Edit operation: append, prepend, find_replace, replace_section",
          "type": "string"
        },
        "section": {
          "description": "Required for replace_section: heading text identifying the section",
          "type": "string"
        },
        "type": {
          "description": "If provided and different from current type, move the note to the new type's folder",
          "type": "string"
        }
      },
      "required": [
        "identifier",
        "operation",
        "content"
      ],
      "type": "object"
    },
    "name": "memory_edit"
  },
  {
    "concurrent_safe": false,
    "description": "Compatibility fallback for note moves when filesystem rename semantics are unavailable. Prefer filesystem note CRUD via the mounted memory tree or checked-in `.djinn/` files. When mounted, `.djinn/memory/` reflects the current session-selected task/worktree view and falls back to canonical `main` when no task view is available; no explicit branch directories are exposed in this slice. Updates permalink and resolves inbound links. Use type=\"proposed_adr\" to recover a mis-routed ADR draft into .djinn/decisions/proposed/ without raw shell relocation.",
    "inputSchema": {
      "properties": {
        "identifier": {
          "description": "Note permalink or title",
          "type": "string"
        },
        "title": {
          "description": "Optional new title; keep current title if omitted.",
          "type": "string"
        },
        "type": {
          "description": "New note type. Use proposed_adr to relocate proposal drafts into decisions/proposed/.",
          "type": "string"
        }
      },
      "required": [
        "identifier",
        "type"
      ],
      "type": "object"
    },
    "name": "memory_move"
  },
