  {
    "concurrent_safe": true,
    "description": "Query the Language Server Protocol for code navigation. Operations: hover (type info at position), definition (go to definition), references (find all references), symbols (list document symbols with optional depth/kind/name filtering). Line and character are 1-based for non-symbol operations.",
    "inputSchema": {
      "properties": {
        "character": {
          "description": "1-based column number (required for hover, definition, references when symbol is omitted)",
          "minimum": 1,
          "type": "integer"
        },
        "depth": {
          "description": "Maximum nesting depth for operation='symbols'. 0 = top-level only; omitted = unlimited",
          "minimum": 0,
          "type": "integer"
        },
        "file_path": {
          "description": "Absolute or worktree-relative file path",
          "type": "string"
        },
        "kind": {
          "description": "Comma-separated symbol kind filter for operation='symbols' (e.g. function,method,struct,class,interface,enum,variable,constant,module,field,property,constructor,type_parameter)",
          "type": "string"
        },
        "line": {
          "description": "1-based line number (required for hover, definition, references)",
          "minimum": 1,
          "type": "integer"
        },
        "name_filter": {
          "description": "Case-insensitive substring filter applied to symbol names and name paths for operation='symbols'",
          "type": "string"
        },
        "operation": {
          "description": "LSP operation to perform",
          "enum": [
            "hover",
            "definition",
            "references",
            "symbols"
          ],
          "type": "string"
        },
        "symbol": {
          "description": "Optional symbol name path for hover, definition, or references as an alternative to line+character",
          "type": "string"
        }
      },
      "required": [
        "operation",
        "file_path"
      ],
      "type": "object"
    },
    "name": "lsp"
  },
  {
    "concurrent_safe": true,
    "description": "Query the repository dependency graph built from SCIP indexer output. Operations: neighbors (edges in/out of a node; group_by=file for per-file rollup), ranked (top nodes by PageRank or degree; sort_by pagerank|in_degree|out_degree|total_degree), impact (transitive dependents; group_by=file for per-file rollup), implementations (find implementors of a trait/interface symbol), search (name-based symbol lookup via query substring), cycles (strongly-connected components of size >= min_size), orphans (zero-incoming-reference nodes filtered by visibility public|private|any), path (shortest dependency path from→to), edges (enumerate edges matching from_glob→to_glob), diff (what changed since the previous canonical graph — only since=previous supported), describe (symbol signature/documentation without an LSP round trip).",
    "inputSchema": {
      "properties": {
        "direction": {
          "description": "Edge direction filter for neighbors (omit for both)",
          "enum": [
            "incoming",
            "outgoing"
          ],
          "type": "string"
        },
        "edge_kind": {
          "description": "Edge-kind filter for edges",
          "type": "string"
        },
        "from": {
          "description": "Source node for path",
          "type": "string"
        },
        "from_glob": {
          "description": "Source path glob for edges",
          "type": "string"
        },
        "group_by": {
          "description": "Group impact/neighbors results by file",
          "enum": [
            "file"
          ],
          "type": "string"
        },
        "key": {
          "description": "Node key: file path or SCIP symbol string (required for neighbors, impact, implementations, describe)",
          "type": "string"
        },
        "kind_filter": {
          "description": "Node kind filter for ranked/search/cycles/orphans",
          "enum": [
            "file",
            "symbol"
          ],
          "type": "string"
        },
        "limit": {
          "description": "Max results (ranked/search/orphans/edges) or max traversal depth (impact)",
          "minimum": 1,
          "type": "integer"
        },
        "max_depth": {
          "description": "Maximum depth for path",
          "minimum": 1,
          "type": "integer"
        },
        "min_size": {
          "description": "Minimum SCC size for cycles (default 2)",
          "minimum": 2,
          "type": "integer"
        },
        "operation": {
          "description": "Graph query to perform",
          "enum": [
            "neighbors",
            "ranked",
            "impact",
            "implementations",
            "search",
            "cycles",
            "orphans",
            "path",
            "edges",
            "diff",
            "describe"
          ],
          "type": "string"
        },
        "project_path": {
          "description": "Absolute path to project root",
          "type": "string"
        },
        "query": {
          "description": "Substring query for search",
          "type": "string"
        },
        "since": {
          "description": "Diff base selector for diff (currently only 'previous')",
          "type": "string"
        },
        "sort_by": {
          "description": "Sort key for ranked (default pagerank)",
          "enum": [
            "pagerank",
            "in_degree",
            "out_degree",
            "total_degree"
          ],
          "type": "string"
        },
        "to": {
          "description": "Destination node for path",
          "type": "string"
        },
        "to_glob": {
          "description": "Destination path glob for edges",
          "type": "string"
        },
        "visibility": {
          "description": "Visibility filter for orphans (default any)",
          "enum": [
            "public",
            "private",
            "any"
          ],
          "type": "string"
        }
      },
      "required": [
        "operation",
        "project_path"
      ],
      "type": "object"
    },
    "name": "code_graph"
