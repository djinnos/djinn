  {
    "concurrent_safe": true,
    "description": "Query the Language Server Protocol for code navigation. Operations: hover (type info at position), definition (go to definition), references (find all references), symbols (list document symbols with optional depth/kind/name filtering). Line and character are 1-based for non-symbol operations.",
    "inputSchema": {
      "properties": {
        "character": {
          "description": "1-based column number (required for hover, definition, references when symbol is omitted)",
          "minimum": 1,
          "type": "integer"
        },
        "depth": {
          "description": "Maximum nesting depth for operation='symbols'. 0 = top-level only; omitted = unlimited",
          "minimum": 0,
          "type": "integer"
        },
        "file_path": {
          "description": "Absolute or worktree-relative file path",
          "type": "string"
        },
        "kind": {
          "description": "Comma-separated symbol kind filter for operation='symbols' (e.g. function,method,struct,class,interface,enum,variable,constant,module,field,property,constructor,type_parameter)",
          "type": "string"
        },
        "line": {
          "description": "1-based line number (required for hover, definition, references)",
          "minimum": 1,
          "type": "integer"
        },
        "name_filter": {
          "description": "Case-insensitive substring filter applied to symbol names and name paths for operation='symbols'",
          "type": "string"
        },
        "operation": {
          "description": "LSP operation to perform",
          "enum": [
            "hover",
            "definition",
            "references",
            "symbols"
          ],
          "type": "string"
        },
        "symbol": {
          "description": "Optional symbol name path for hover, definition, or references as an alternative to line+character",
          "type": "string"
        }
      },
      "required": [
        "operation",
        "file_path"
      ],
      "type": "object"
    },
    "name": "lsp"
  },
  {
    "concurrent_safe": true,
    "description": "Query the SCIP-built repository dependency graph. Set `operation` to one of the enum values; most ops accept optional filters (kind_filter, group_by, limit, min_confidence). Call `operation=capabilities` for the full per-op param shapes + defaults. Quick guide: neighbors / ranked / impact / implementations / search / cycles / orphans / path / edges — basic graph queries (impact defaults: depth=2, min_confidence=0.85, behavioural edges only). symbols_at / diff_touches / detect_changes — line-range → touched symbols. describe / context — single-symbol detail (context = bucketed incoming/outgoing edges). status / metrics_at / snapshot — graph health + introspection. api_surface / dead_symbols / deprecated_callers — public surface health. boundary_check / blast_radius / touches_hot_path — change-impact analysis. hotspots / cochange / churn / coupling_hubs — git-coupling × PageRank centrality. complexity — rank functions or files by cognitive/cyclomatic/nloc complexity. refactor_candidates — composite refactor-priority ranking (cognitive × churn × pagerank z-score).",
    "inputSchema": {
      "properties": {
        "changed_ranges": {
          "description": "List of changed line ranges for diff_touches (parsed from `git diff --unified=0 base..head`)",
          "items": {
            "properties": {
              "end_line": {
                "description": "1-indexed inclusive last line of the hunk (defaults to start_line)",
                "minimum": 1,
                "type": "integer"
              },
              "file": {
                "description": "Repository-relative path of the changed file",
                "type": "string"
              },
              "start_line": {
                "description": "1-indexed inclusive first line of the hunk",
                "minimum": 1,
                "type": "integer"
              }
            },
            "required": [
              "file",
              "start_line"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "confidence": {
          "description": "Confidence tier for dead_symbols (default high)",
          "enum": [
            "high",
            "med",
            "low"
          ],
          "type": "string"
        },
        "direction": {
          "description": "Edge direction filter for neighbors (omit for both)",
          "enum": [
            "incoming",
            "outgoing"
          ],
          "type": "string"
        },
        "edge_kind": {
          "description": "Edge-kind filter for edges",
          "type": "string"
        },
        "end_line": {
          "description": "1-indexed inclusive end line for symbols_at (defaults to start_line)",
          "minimum": 1,
          "type": "integer"
        },
        "file": {
          "description": "Repository-relative file path (required for symbols_at)",
          "type": "string"
        },
        "file_glob": {
          "description": "File-path glob restricting hotspots to a subset of files",
          "type": "string"
        },
        "from": {
          "description": "Source node for path",
          "type": "string"
        },
        "from_glob": {
          "description": "Source path glob for edges",
          "type": "string"
        },
        "group_by": {
          "description": "Group impact/neighbors results by file",
          "enum": [
            "file"
          ],
          "type": "string"
        },
        "key": {
          "description": "Node key: file path or SCIP symbol string (required for neighbors, impact, implementations, describe)",
          "type": "string"
        },
        "kind_filter": {
          "description": "Node kind filter for ranked/search/cycles/orphans",
          "enum": [
            "file",
            "symbol"
          ],
          "type": "string"
        },
        "limit": {
          "description": "Max results (ranked/search/orphans/edges) or max traversal depth (impact)",
          "minimum": 1,
          "type": "integer"
        },
        "max_depth": {
          "description": "Maximum depth for path",
          "minimum": 1,
          "type": "integer"
        },
        "min_size": {
          "description": "Minimum SCC size for cycles (default 2)",
          "minimum": 2,
          "type": "integer"
        },
        "mode": {
          "description": "Search mode for the `search` op (PR B4). `name` runs the canonical-graph name index only (fast path); `hybrid` blends lexical + semantic + structural via RRF k=60 and stamps each hit with a `match_kind` tag for debug surfaces. Default reads `DJINN_CODE_GRAPH_SEARCH_DEFAULT_MODE` (env var; defaults to `name`).",
          "enum": [
            "name",
            "hybrid"
          ],
          "type": "string"
        },
        "module_glob": {
          "description": "File-path glob restricting api_surface to a subset of symbols",
          "type": "string"
        },
        "operation": {
          "description": "Graph query to perform",
          "enum": [
            "neighbors",
            "ranked",
            "impact",
            "implementations",
            "search",
            "cycles",
            "orphans",
            "path",
            "edges",
            "symbols_at",
            "diff_touches",
            "detect_changes",
            "describe",
            "context",
            "api_surface",
            "boundary_check",
            "blast_radius",
            "hotspots",
            "complexity",
            "refactor_candidates",
            "cochange",
            "churn",
            "coupling_hubs",
            "metrics_at",
            "dead_symbols",
            "deprecated_callers",
            "touches_hot_path",
            "status",
            "snapshot",
            "capabilities"
          ],
          "type": "string"
        },
        "project": {
          "description": "Project slug (owner/repo) or UUID. The handler resolves it to the server-managed clone path.",
          "type": "string"
        },
        "query": {
          "description": "Substring query for search",
          "type": "string"
        },
        "rules": {
          "description": "Boundary rules for boundary_check. Every submitted rule is treated as a forbidden edge; matching edges are reported as violations.",
          "items": {
            "properties": {
              "from_glob": {
                "description": "Source path glob",
                "type": "string"
              },
              "to_glob": {
                "description": "Destination path glob",
                "type": "string"
              }
            },
            "required": [
              "from_glob",
              "to_glob"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "seed_entries": {
          "description": "Entry-point SCIP symbol keys for touches_hot_path",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "seed_sinks": {
          "description": "Sink SCIP symbol keys for touches_hot_path",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "sort_by": {
          "description": "Sort key. For ranked: pagerank|in_degree|out_degree|total_degree (default pagerank). For complexity: cognitive|cyclomatic|nloc|max_nesting|param_count (default cognitive).",
          "enum": [
            "pagerank",
            "in_degree",
            "out_degree",
            "total_degree",
            "cognitive",
            "cyclomatic",
            "nloc",
            "max_nesting",
            "param_count"
          ],
          "type": "string"
        },
        "start_line": {
          "description": "1-indexed inclusive start line (required for symbols_at)",
          "minimum": 1,
          "type": "integer"
        },
        "symbols": {
          "description": "Queried symbol keys for touches_hot_path",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "target": {
          "description": "Target tier for complexity (default functions). 'files' aggregates by file_path.",
          "enum": [
            "functions",
            "files"
          ],
          "type": "string"
        },
        "to": {
          "description": "Destination node for path",
          "type": "string"
        },
        "to_glob": {
          "description": "Destination path glob for edges",
          "type": "string"
        },
        "visibility": {
          "description": "Visibility filter for orphans (default any)",
          "enum": [
            "public",
            "private",
            "any"
          ],
          "type": "string"
        },
        "window_days": {
          "description": "Churn look-back window in days for hotspots (default 90, clamped to 365)",
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "operation",
        "project"
      ],
      "type": "object"
    },
    "name": "code_graph"
  },
  {
    "concurrent_safe": true,
    "description": "Given a PR's changed line ranges (parsed from `git diff --unified=0 base..head`), assemble the base-graph signals that matter for review in one call: touched symbols with fan-in/out, blast radius, hotspot overlap, touched cycles, deprecated-caller hits, hot-path overlap, and architecture-boundary violations. Base-graph-only — does NOT build a head graph, detect newly-introduced cycles, or parse the diff text for removed-API detection. Every list is capped (defaults: touched_symbols=100, blast_radius=50, hotspot_overlap=20, touched_cycles=20, touched_boundary_violations=50, touched_deprecated=20, hot_path_overlap=20).",
    "inputSchema": {
      "properties": {
        "boundary_rules": {
          "description": "Architecture boundary rules; when empty, boundary analysis is skipped",
          "items": {
            "properties": {
              "forbidden": {
                "type": "boolean"
              },
              "from_glob": {
                "type": "string"
              },
              "to_glob": {
                "type": "string"
              }
            },
            "required": [
              "from_glob",
              "to_glob",
              "forbidden"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "caps": {
          "description": "Per-list result caps; missing fields use defaults",
          "properties": {
            "blast_radius": {
              "minimum": 0,
              "type": "integer"
            },
            "hot_path_overlap": {
              "minimum": 0,
              "type": "integer"
            },
            "hotspot_overlap": {
              "minimum": 0,
              "type": "integer"
            },
            "touched_boundary_violations": {
              "minimum": 0,
              "type": "integer"
            },
            "touched_cycles": {
              "minimum": 0,
              "type": "integer"
            },
            "touched_deprecated": {
              "minimum": 0,
              "type": "integer"
            },
            "touched_symbols": {
              "minimum": 0,
              "type": "integer"
            }
          },
          "type": "object"
        },
        "changed_ranges": {
          "description": "List of changed line ranges parsed from `git diff --unified=0 base..head`",
          "items": {
            "properties": {
              "end_line": {
                "description": "1-indexed inclusive last line of the hunk (defaults to start_line)",
                "minimum": 1,
                "type": "integer"
              },
              "file": {
                "description": "Repository-relative path of the changed file",
                "type": "string"
              },
              "start_line": {
                "description": "1-indexed inclusive first line of the hunk",
                "minimum": 1,
                "type": "integer"
              }
            },
            "required": [
              "file",
              "start_line"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "hotspots_window_days": {
          "description": "Churn look-back window for hotspot overlap (default 90)",
          "minimum": 1,
          "type": "integer"
        },
        "project": {
          "description": "Project slug (owner/repo) or UUID. The handler resolves it to the server-managed clone path.",
          "type": "string"
        },
        "seed_entries": {
          "description": "Entry-point SCIP keys for hot-path overlap (optional)",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "seed_sinks": {
          "description": "Sink SCIP keys for hot-path overlap (optional)",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "project",
        "changed_ranges"
      ],
      "type": "object"
    },
    "name": "pr_review_context"
  },
  {
    "concurrent_safe": true,
    "description": "Fetch the full log for a GitHub Actions CI job. When CI fails, the activity log tells you the job_id. Call this tool to see the actual error output. Optionally filter to a specific failed step name. If the output is large, use output_view or output_grep to navigate it.",
    "inputSchema": {
      "properties": {
        "job_id": {
          "description": "The GitHub Actions job ID from the CI failure activity",
          "type": "integer"
        },
        "step": {
          "description": "Optional step name to filter the log to (e.g. 'Tests')",
          "type": "string"
        }
      },
      "required": [
        "job_id"
      ],
      "type": "object"
    },
    "name": "ci_job_log"
  },
  {
    "concurrent_safe": true,
    "description": "Search GitHub code across public repositories using the GitHub Code Search API. Returns compact, navigable matches with snippets, file paths, URLs, and metadata. Each result has a result_id for reference. Use github_fetch_file to inspect the full file of a promising result.",
    "inputSchema": {
      "properties": {
        "language": {
          "description": "Programming language filter (e.g. \"Rust\", \"Python\", \"TypeScript\")",
          "type": "string"
        },
        "path": {
          "description": "Path filter to search within specific directories (e.g. \"src/\")",
          "type": "string"
        },
        "query": {
          "description": "Search query. Supports GitHub code search syntax.",
          "type": "string"
        },
        "repo": {
          "description": "Repository filter in \"owner/repo\" format (e.g. \"tokio-rs/tokio\")",
          "type": "string"
        }
      },
      "required": [
        "query"
      ],
      "type": "object"
    },
    "name": "github_search"
  },
  {
    "concurrent_safe": true,
    "description": "Fetch the full contents of a file from a public GitHub repository. Use after github_search to inspect a promising result. Supports optional start_line/end_line for reading specific sections of large files.",
    "inputSchema": {
      "properties": {
        "end_line": {
          "description": "Last line to return (1-based, inclusive)",
          "type": "integer"
        },
        "path": {
          "description": "File path within the repository (e.g. \"src/lib.rs\")",
          "type": "string"
        },
        "ref": {
          "description": "Branch, tag, or commit SHA (default: default branch)",
          "type": "string"
        },
        "repo": {
          "description": "Repository in \"owner/repo\" format (e.g. \"tokio-rs/tokio\")",
          "type": "string"
        },
        "start_line": {
          "description": "First line to return (1-based, inclusive)",
          "type": "integer"
        }
      },
      "required": [
        "repo",
        "path"
      ],
      "type": "object"
    },
    "name": "github_fetch_file"
  },
  {
    "concurrent_safe": true,
    "description": "Paginated view of a truncated tool output. When a tool result was truncated, the full output is stashed and can be browsed here by tool_use_id.",
    "inputSchema": {
      "properties": {
        "limit": {
          "description": "Number of lines to return (default 200)",
          "minimum": 1,
          "type": "integer"
        },
        "offset": {
          "description": "Line offset (0-based, default 0)",
          "minimum": 0,
          "type": "integer"
        },
        "tool_use_id": {
          "description": "The tool_use_id from the truncated result",
          "type": "string"
        }
      },
      "required": [
        "tool_use_id"
      ],
      "type": "object"
    },
    "name": "output_view"
  },
  {
    "concurrent_safe": true,
    "description": "Regex search within a truncated tool output. Returns matching lines with context from the full stashed output.",
    "inputSchema": {
      "properties": {
        "context_lines": {
          "description": "Lines of context around each match (default 3)",
          "minimum": 0,
          "type": "integer"
        },
        "pattern": {
          "description": "Regex pattern to search for",
          "type": "string"
        },
        "tool_use_id": {
          "description": "The tool_use_id from the truncated result",
          "type": "string"
        }
      },
      "required": [
        "tool_use_id",
        "pattern"
      ],
      "type": "object"
    },
    "name": "output_grep"
  },
  {
    "concurrent_safe": false,
    "description": "Create a new task under an epic. Agents should use this only when explicitly allowed by their role and task design.",
    "inputSchema": {
      "properties": {
        "acceptance_criteria": {
          "description": "Required. Each item is either a plain string or an object with 'criterion' (string) and optional 'met' (bool) fields. Tasks without acceptance criteria cannot be dispatched.",
          "items": {},
          "minItems": 1,
          "type": "array"
        },
        "blocked_by": {
          "description": "Task IDs (UUID or short_id) that must complete before this task can be dispatched.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "description": {
          "type": "string"
        },
        "design": {
          "type": "string"
        },
        "epic_id": {
          "description": "Parent epic UUID or short ID",
          "type": "string"
        },
        "issue_type": {
          "description": "Task type: 'task' (default for worker-routed code work), 'planning' for epic metadata operations (epic_update, epic_close, memory_refs management, roadmap/AC changes, or other metadata-only maintenance), 'spike' for research, 'review' for code review. Use 'planning' when the work requires epic management tools or primarily updates epic metadata instead of code.",
          "type": "string"
        },
        "labels": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "owner": {
          "type": "string"
        },
        "parent_id": {
          "type": "string"
        },
        "priority": {
          "type": "integer"
        },
        "status": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "epic_id",
        "title",
        "acceptance_criteria"
      ],
      "type": "object"
    },
    "name": "task_create"
  },
  {
    "concurrent_safe": false,
    "description": "Update task fields and manage blocker relationships. Use blocked_by_add/blocked_by_remove to enforce task sequencing — a task with unresolved blockers will not be dispatched.",
    "inputSchema": {
