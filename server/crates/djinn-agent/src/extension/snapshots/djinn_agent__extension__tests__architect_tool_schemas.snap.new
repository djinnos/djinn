    "description": "Build context from a memory note with progressive disclosure. Returns full content for primary notes, overview for direct linked notes, abstract for discovered related notes. Use url='folder/*' to return all notes in a folder. Seed notes are never dropped by budget constraints.",
    "inputSchema": {
      "properties": {
        "budget": {
          "description": "Token budget for context (default 4096)",
