{
  "db_name": "MySQL",
  "query": "SELECT n.id, n.project_id, n.permalink, n.title, n.note_type, n.folder, n.scope_paths, n.content,\n                    n.`abstract` AS abstract_, n.overview, n.confidence\n             FROM notes n\n             JOIN consolidated_note_provenance cnp ON cnp.note_id = n.id\n             WHERE n.project_id = ?\n               AND n.note_type = ?\n               AND n.storage = 'db'\n               AND cnp.session_id = ?\n             ORDER BY n.permalink ASC, n.id ASC",
