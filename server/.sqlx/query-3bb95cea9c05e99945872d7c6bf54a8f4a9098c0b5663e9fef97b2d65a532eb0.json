{
  "db_name": "MySQL",
  "query": "SELECT src.id, src.permalink, src.title, l.target_raw\n             FROM note_links l\n             JOIN notes src ON src.id = l.source_id AND src.project_id = ?\n             WHERE l.target_id IS NULL\n               AND (? IS NULL OR src.folder = ?)\n             ORDER BY src.permalink, l.target_raw",
