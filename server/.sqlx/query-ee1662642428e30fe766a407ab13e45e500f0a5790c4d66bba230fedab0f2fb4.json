{
  "db_name": "MySQL",
  "query": "SELECT h.id, h.agent_id, h.created_at, h.proposed_text, h.metrics_before\n             FROM learned_prompt_history h\n             JOIN agents r ON r.id = h.agent_id\n             WHERE r.project_id = ?\n               AND h.action = 'keep'\n               AND h.metrics_after IS NULL\n             ORDER BY h.created_at ASC",
