  "query": "SELECT t.id AS task_id, t.short_id, t.title, t.`status` AS \"status!\"\n                 FROM blockers b\n                 JOIN tasks t ON t.id = b.task_id\n                 WHERE b.blocking_task_id = ?\n                   AND t.`status` != 'closed'",
