{
  "db_name": "MySQL",
  "query": "SELECT n.id, n.permalink, n.title, n.note_type, n.folder\n             FROM notes n\n             WHERE n.project_id = ?\n               AND n.note_type NOT IN ('brief', 'roadmap', 'catalog')\n               AND (? IS NULL OR n.folder = ?)\n               AND NOT EXISTS (\n                   SELECT 1 FROM note_links l WHERE l.target_id = n.id\n               )\n             ORDER BY n.folder, n.title",
