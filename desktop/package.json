{
  "name": "djinnos-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "DjinnOS Desktop Application",
  "author": "DjinnOS Team <team@djinnos.com>",
  "repository": "github:djinnos/djinn",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "mcp:types": "tsx scripts/generate-mcp-types.ts --source=live",
    "mcp:types:snapshot": "tsx scripts/generate-mcp-types.ts --source=snapshot",
    "mcp:types:check": "pnpm mcp:types:snapshot && git diff --exit-code -- src/api/generated/mcp-tools.gen.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "electron:compile": "tsc -p electron/tsconfig.json && tsc -p electron/tsconfig.preload.json",
    "electron:dev": "pnpm electron:compile && VITE_DEV_SERVER_URL=http://localhost:1420 electron dist-electron/main.js --dev",
    "electron:start": "pnpm dev & sleep 2 && pnpm electron:dev",
    "electron:build": "pnpm build && pnpm electron:compile && electron-builder",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run --pool=vmThreads",
    "test:watch": "vitest --pool=vmThreads",
    "test:typecheck": "tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@hugeicons/core-free-icons": "^3.3.0",
    "@hugeicons/react": "^1.1.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@rive-app/react-webgl2": "^4.27.3",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.96.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.143",
    "ansi-to-react": "^6.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "lucide-react": "^0.576.0",
    "media-chrome": "^4.18.3",
    "motion": "^12.38.0",
    "nanoid": "^5.1.7",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-jsx-parser": "^2.4.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.13.2",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.0",
    "shadcn": "^3.8.5",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tokenlens": "^1.3.1",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@storybook/addon-a11y": "9.1.19",
    "@storybook/addon-docs": "9.1.19",
    "@storybook/addon-links": "9.1.19",
    "@storybook/react-vite": "9.1.19",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-storybook": "9.1.19",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "json-schema-to-typescript": "^15.0.4",
    "storybook": "9.1.19",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  }
}
