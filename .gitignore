# Djinn task management
.djinn/worktrees/
.djinn/.obsidian/
.planning/
.claude/
.djinn/cases/
.djinn/patterns/
.djinn/pitfalls/

# Build / test artifacts
target/
target-*/
.cargo-target/
tmp/
.tmp/
.tmp-test/
test-tmp/

# MCP config (machine-specific paths, may contain API keys)
mcp.json
.mcp.json

# Package manager stores
.pnpm-store/
node_modules/

# Local secrets — pem files, vault keys, kubectl --from-file targets.
# Drop anything sensitive into local-secrets/. The dir + README are tracked
# so the path exists; everything else is ignored.
/local-secrets/*
!/local-secrets/.gitkeep
!/local-secrets/README.md
