{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "djinn-server --ensure-daemon"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node '${CLAUDE_PLUGIN_ROOT}/hooks/djinn-context-monitor.js'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node '${CLAUDE_PLUGIN_ROOT}/hooks/djinn-statusline.js'"
  }
}
