{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    "shell:allow-open",
    "shell:allow-spawn",
    "shell:allow-kill",
    "process:default",
    "process:allow-restart",
    "process:allow-exit",
    "core:window:allow-show"
  ]
}
